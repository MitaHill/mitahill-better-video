# Task Lifecycle
TASK_TTL_HOURS=12

# Processing Defaults
DEFAULT_UPSCALE_FACTOR=2
DEFAULT_MODEL_NAME=realesrgan-x4plus
DEFAULT_TILE_SIZE=0
DEFAULT_TILE_PADDING=10
DEFAULT_FP16=true
DEFAULT_CRF=18
DEFAULT_KEEP_AUDIO=true

# Fallback VRAM in GB (used if nvidia-smi fails)
FALLBACK_VRAM_GB=4

# Upload Limits
MAX_VIDEO_SIZE_MB=1024
MAX_IMAGE_SIZE_MB=1024