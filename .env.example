# Real-ESRGAN Web App Configuration Template

# Task Lifecycle
# Auto-delete tasks and files after X hours (supports float, e.g., 0.5 = 30 mins)
TASK_TTL_HOURS=12

# Processing Defaults
DEFAULT_UPSCALE_FACTOR=2
# Available models: realesrgan-x4plus, realesrnet-x4plus, realesrgan-x4plus-anime, realesr-animevideov3
DEFAULT_MODEL_NAME=realesrgan-x4plus
# Set to 0 to auto-calculate based on VRAM, or set a specific size (e.g. 512, 256)
DEFAULT_TILE_SIZE=0
DEFAULT_TILE_PADDING=10
DEFAULT_FP16=true
DEFAULT_CRF=18
DEFAULT_KEEP_AUDIO=true

# Video Segmentation
# Split long videos into segments of X seconds to save RAM/Storage
SEGMENT_TIME_SECONDS=300

# Fallback VRAM in GB (used if nvidia-smi fails inside container)
FALLBACK_VRAM_GB=4

# Upload Limits (in MB)
# Note: Streamlit has an internal hard limit, but this config sets the application validation.
MAX_VIDEO_SIZE_MB=1024
MAX_IMAGE_SIZE_MB=1024
